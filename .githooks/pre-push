#!/bin/sh
set -e

# Pre-push policy: only fast, environment-independent checks belong here.
# Anything requiring secrets, network access, or a full build runs in CI.
# (Growth gates moved to scheduled workflows; preflight build removed - CI builds every PR.)

echo "branch push policy guard..."
node scripts/check-no-direct-main-push.mjs

echo "push clean-worktree guard..."
npm run guard:push-clean-worktree

echo "ux/ui rubric page gate..."
npm run ux:rubric:pages

echo "public asset tracking guard..."
npm run guard:public-assets

echo "ok"