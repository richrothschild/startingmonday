#!/bin/sh
set -e

echo "push clean-worktree guard..."
npm run guard:push-clean-worktree

guide_checks_required=false
while read local_ref local_sha remote_ref remote_sha
do
	case "$remote_sha" in
		0000000000000000000000000000000000000000)
			guide_checks_required=true
			;;
		*)
			changed_files=$(git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null || true)
			if [ -n "$changed_files" ] && printf '%s\n' "$changed_files" | node scripts/guide-freshness-needed.mjs | grep -qx yes; then
				guide_checks_required=true
			fi
			;;
	esac
done

if [ "$guide_checks_required" = true ]; then
	echo "guide freshness checks..."
	if ! npm run guide:user:check; then
		echo "user-guide is stale. run: npm run guide:user:sync && git add docs/user-guide.*"
		exit 1
	fi

	if ! npm run guide:internal:check; then
		echo "internal-guide is stale. run: npm run guide:internal:sync && git add docs/internal-guide.* docs/internal-system-summary.md"
		exit 1
	fi

	echo "guide freshness checks... ran because pushed commits touched guide inputs"
else
	echo "guide freshness checks... skipped (no guide inputs changed)"
fi

echo "growth council gate..."
npm run growth:council:strict

echo "growth metrics gate..."
npm run growth:metrics:strict

echo "ux/ui rubric page gate..."
npm run ux:rubric:pages

echo "push Playwright guard..."
if ! npm run guard:push:playwright; then
	echo ""
	echo "❌ E2E tests failed! Push blocked."
	echo "   Run: npm run test:e2e:auth-ux && npm run test:e2e:luxury"
	echo "   Fix failures locally before pushing again."
	exit 1
fi

echo "push environment-sensitive guard..."
if [ -n "${NEXT_PUBLIC_SUPABASE_URL:-}" ] && [ -n "${SUPABASE_SERVICE_ROLE_KEY:-}" ]; then
	npm run guard:push:env
else
	echo "push environment-sensitive guard... skipped (missing NEXT_PUBLIC_SUPABASE_URL or SUPABASE_SERVICE_ROLE_KEY)"
fi

if [ "${SKIP_PRE_PUSH_BUILD:-0}" = "1" ]; then
	echo "skipping Railway preflight build because SKIP_PRE_PUSH_BUILD=1"
else
	echo "push Railway preflight build..."
	npm run railway:preflight
fi

echo "ok"