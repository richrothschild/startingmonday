# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only; never expose to client

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Browserless ─────────────────────────────────────────────────────────────
# Used by the Railway worker for headless career-page scanning
BROWSERLESS_API_KEY=your-browserless-key

# ─── Resend ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=briefing@startingmonday.app   # must match verified sending domain

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...            # sk_test_... for local dev
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...   # pk_test_... for local dev
# Stripe price IDs - create these in the Stripe dashboard
STRIPE_PRICE_PASSIVE=price_...           # Intelligence monthly ($49/mo)
STRIPE_PRICE_ACTIVE=price_...            # Search monthly ($129/mo)
STRIPE_PRICE_EXECUTIVE=price_...         # Executive monthly ($249/mo)
STRIPE_PRICE_PASSIVE_ANNUAL=price_...    # Intelligence annual ($490/yr)
STRIPE_PRICE_ACTIVE_ANNUAL=price_...     # Search annual ($1,290/yr)
STRIPE_PRICE_EXECUTIVE_ANNUAL=price_...  # Executive annual ($2,490/yr)
# Legacy - keep if Railway already has this set (backward compat with 'monitor' naming)
# STRIPE_PRICE_MONITOR=price_...         # same price ID as STRIPE_PRICE_PASSIVE

# ─── Crunchbase ──────────────────────────────────────────────────────────────
# Used by the worker to fetch funding round signals. Basic API plan.
# Get a key at https://data.crunchbase.com/docs/using-the-api
CRUNCHBASE_API_KEY=your-crunchbase-key

# ─── PDL (People Data Labs) ──────────────────────────────────────────────────
# Used by the worker to fetch executive roster snapshots for departure/hire detection.
PDL_API_KEY=your-pdl-key

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...   # same value; needed for client-side capture

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # https://startingmonday.app in production
NEXT_PUBLIC_CHANNEL_ENTRY_AB_TEST=0          # set to 1 in staging to enable channel entry A/B test
OWNER_EMAIL=richard@startingmonday.app     # receives new signup, placement, and scan alerts
UX_WEEKLY_REVIEW_EMAIL_TO=rothschild@gmail.com # weekly site-wide UI/UX review destination
CRON_SECRET=your-cron-secret-here          # required for worker-triggered cron routes
# Email open tracking token signing
PIXEL_TOKEN_SECRET=replace-with-strong-random-secret
PIXEL_TOKEN_REQUIRE_SIGNATURE=false         # set true after signed-token rollout is fully deployed

# ─── Social publishing ───────────────────────────────────────────────────────
MAKE_WEBHOOK_URL=https://hook.make.com/... # receives auto-post payloads from /api/admin/social/*
LINKEDIN_POST_TARGET=personal              # personal or company
LINKEDIN_COMPANY_URN=urn:li:organization:123456789
# LinkedIn OAuth access token for engagement sync (r_member_social or r_organization_social scope)
# Configure your Make.com scenario to return { "linkedin_post_urn": "urn:li:ugcPost:..." }
# then the daily sync-engagement cron will pull likes/comments via LinkedIn REST API v2
LINKEDIN_ACCESS_TOKEN=

# Optional: weekly UI/UX review Slack delivery
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_USER_TOKEN=
SLACK_ALERT_CHANNEL_ID=
SLACK_CHANNEL_ID=

# ─── Worker ──────────────────────────────────────────────────────────────────
# URL of the Railway worker service. Use the Railway internal URL when both services
# are in the same project: https://<service-name>.railway.internal
# The worker handles scanning and timezone-aware briefing delivery.
WORKER_URL=https://your-worker-service.railway.app
# Shared secret — generate with: openssl rand -hex 32
# Set the same value on both the Next.js service and the worker service.
WORKER_SECRET=your-worker-secret-here

# ─── Briefing cron (DEPRECATED — worker handles briefings now) ───────────────
# Kept for reference. Disable the cron-job.org trigger once the worker is deployed.
BRIEFING_CRON_SECRET=your-secret-here
