# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only; never expose to client

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Browserless ─────────────────────────────────────────────────────────────
# Used by the Railway worker for headless career-page scanning
BROWSERLESS_API_KEY=your-browserless-key

# ─── Resend ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=briefing@startingmonday.app   # must match verified sending domain

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...            # sk_test_... for local dev
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...   # pk_test_... for local dev

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...   # same value; needed for client-side capture

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # https://startingmonday.app in production

# ─── Briefing cron ───────────────────────────────────────────────────────────
# Random secret string. Pass as x-cron-secret header when calling POST /api/briefing/send
# Configure Railway cron to call: POST https://startingmonday.app/api/briefing/send
# at 12:00 UTC daily (8 AM ET). Header: x-cron-secret: $BRIEFING_CRON_SECRET
BRIEFING_CRON_SECRET=your-secret-here
