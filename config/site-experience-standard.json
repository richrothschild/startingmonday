{
  "version": 1,
  "capturedAt": "2026-07-11T00:00:00.000Z",
  "reviewBy": "2026-10-09T00:00:00.000Z",
  "description": "Site Experience Standard (SES). Canonical budgets, grade thresholds, and severity rules for SXO agents and gates.",
  "tiers": {
    "funnel": {
      "label": "Public funnel routes",
      "cwvBudget": {
        "lcpP75Ms": 2000,
        "ttfbP75Ms": 500,
        "clsP75": 0.05,
        "inpP75Ms": 150
      },
      "gradeThresholds": {
        "cognitiveFluency": "B+",
        "cognitiveLoad": "B+"
      }
    },
    "dashboard": {
      "label": "Authenticated dashboard routes",
      "cwvBudget": {
        "lcpP75Ms": 2200,
        "ttfbP75Ms": 600,
        "clsP75": 0.05,
        "inpP75Ms": 170
      },
      "gradeThresholds": {
        "cognitiveFluency": "A-",
        "cognitiveLoad": "A-"
      },
      "trustContracts": {
        "signalParityRequired": true,
        "singleMainLandmarkRequired": true,
        "titlePattern": "<Route Label> - Starting Monday",
        "staleRelativeTimePhrasesAllowed": false
      }
    },
    "public": {
      "label": "Public non-funnel routes",
      "cwvBudget": {
        "lcpP75Ms": 2200,
        "ttfbP75Ms": 600,
        "clsP75": 0.08,
        "inpP75Ms": 180
      },
      "gradeThresholds": {
        "cognitiveFluency": "B+",
        "cognitiveLoad": "B+"
      }
    },
    "admin": {
      "label": "Administrative routes",
      "cwvBudget": {
        "lcpP75Ms": 2500,
        "ttfbP75Ms": 700,
        "clsP75": 0.08,
        "inpP75Ms": 200
      },
      "gradeThresholds": {
        "cognitiveFluency": "B",
        "cognitiveLoad": "B"
      }
    }
  },
  "visualDiscipline": {
    "maxDistinctFontFamilies": 2,
    "maxAccentColorFamilies": 2,
    "motion": {
      "maxConcurrentAnimations": 6,
      "maxDurationMs": 450,
      "layoutShiftingAnimationAllowed": false
    }
  },
  "journeySynthetic": {
    "defaultThresholds": {
      "warnStepP95Ms": 6000,
      "criticalStepP95Ms": 12000
    },
    "tierThresholds": {
      "funnel": {
        "warnStepP95Ms": 5500,
        "criticalStepP95Ms": 10000
      },
      "dashboard": {
        "warnStepP95Ms": 6500,
        "criticalStepP95Ms": 12000
      },
      "public": {
        "warnStepP95Ms": 6000,
        "criticalStepP95Ms": 11000
      },
      "admin": {
        "warnStepP95Ms": 7500,
        "criticalStepP95Ms": 13000
      }
    },
    "tierRiskWeight": {
      "funnel": 1.15,
      "dashboard": 1.25,
      "public": 1,
      "admin": 0.9
    },
    "riskWeights": {
      "failureRatio": 70,
      "slowStepRatio": 20,
      "criticalSlowStepRatio": 10
    }
  },
  "severityPolicy": {
    "P0": {
      "description": "Immediate trust/availability or severe budget failure.",
      "examples": [
        "dashboard parity mismatch",
        "route availability failure on critical route",
        "single run > 2x LCP budget with corroborating signal"
      ],
      "slack": "immediate",
      "digest": true
    },
    "P1": {
      "description": "Budget breach or grade-band drop requiring same-day triage.",
      "slack": "daily-digest",
      "digest": true
    },
    "P2": {
      "description": "Drift within tolerance band, trend-only visibility.",
      "slack": "weekly-only",
      "digest": false
    }
  },
  "dedupe": {
    "windowHours": 72,
    "key": [
      "route",
      "dimension",
      "signature"
    ]
  },
  "baselineLifecycle": {
    "ratchetOnly": true,
    "maxBaselineAgeDays": 90,
    "requiresPullRequest": true
  },
  "reporting": {
    "slackChannel": "reliability---service",
    "labDataFooterRequired": true,
    "messageGrammar": "headline-channel-sections"
  }
}
