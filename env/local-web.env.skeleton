# Starting Monday - local web env skeleton (worker-trigger support)
# Copy keys into your real .env.local file and replace placeholders.

# Local web app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Worker base URL reachable from the web app process.
# If worker runs locally on default port:
WORKER_URL=http://localhost:3001

# Shared secret used by web app to authenticate calls to worker.
# Must match worker/.env WORKER_SECRET exactly.
WORKER_SECRET=replace-with-strong-random-secret
