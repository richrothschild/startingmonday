# Starting Monday - local worker env skeleton (minimum for trigger endpoints)
# Copy keys into worker/.env and replace placeholders.

# Worker listener
PORT=3001
HOST=0.0.0.0

# Shared secret used by worker to validate incoming requests from web app.
# Must match .env.local WORKER_SECRET exactly.
WORKER_SECRET=replace-with-strong-random-secret

# Required backend dependencies for worker runtime.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
ANTHROPIC_API_KEY=replace-with-anthropic-key
RESEND_API_KEY=replace-with-resend-key
RESEND_FROM_ADDRESS=briefing@startingmonday.app
SENTRY_DSN=replace-with-sentry-dsn

# Scanner providers (required for full signal/scan quality)
BROWSERLESS_API_KEY=replace-with-browserless-key
PDL_API_KEY=replace-with-pdl-key

# Optional signal providers
CRUNCHBASE_API_KEY=optional
PREDICTLEADS_API_KEY=optional
