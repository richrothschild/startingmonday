{
  "name": "startingmonday",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run prebuild:guard && next build",
    "prebuild:guard": "node scripts/prebuild-guard.mjs",
    "start": "next start",
    "lint": "eslint",
    "monitor:smoke": "node scripts/production-smoke-check.mjs",
    "monitor:smoke:json": "node scripts/production-smoke-check.mjs --json",
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "check:auth": "sh scripts/check-auth.sh",
    "security:api-guards": "node scripts/check-api-guards.mjs",
    "security:api-guards:json": "node scripts/check-api-guards.mjs --json",
    "security:api-guards:strict": "node scripts/check-api-guards.mjs --strict",
    "sprint5:ads-gate": "node scripts/check-linkedin-ads-gate.mjs",
    "sprint5:ads-gate:json": "node scripts/check-linkedin-ads-gate.mjs --json",
    "sprint5:ads-gate:strict": "node scripts/check-linkedin-ads-gate.mjs --strict",
    "test:e2e": "playwright test --project=setup --project=smoke",
    "test:e2e:report": "playwright show-report",
    "seed:demo": "npx tsx scripts/seed-demo.ts",
    "evals:label-progress": "node scripts/check-prep-brief-label-progress.mjs",
    "evals:label-progress:json": "node scripts/check-prep-brief-label-progress.mjs --json",
    "evals:label-progress:strict": "node scripts/check-prep-brief-label-progress.mjs --strict",
    "evals:label-progress:strict:json": "node scripts/check-prep-brief-label-progress.mjs --strict --json",
    "evals:export-golden-set": "node scripts/export-prep-brief-golden-set.mjs",
    "evals:export-golden-set:dry-run": "node scripts/export-prep-brief-golden-set.mjs --dry-run",
    "evals:export-golden-set:json": "node scripts/export-prep-brief-golden-set.mjs --json",
    "evals:export-golden-set:dry-run:json": "node scripts/export-prep-brief-golden-set.mjs --dry-run --json",
    "evals:verify-golden-set": "node scripts/verify-prep-brief-golden-set.mjs",
    "evals:verify-golden-set:json": "node scripts/verify-prep-brief-golden-set.mjs --json",
    "evals:verify-golden-set:strict": "node scripts/verify-prep-brief-golden-set.mjs --strict",
    "evals:verify-golden-set:strict:json": "node scripts/verify-prep-brief-golden-set.mjs --strict --json",
    "evals:readiness": "node scripts/check-prep-brief-evals-readiness.mjs",
    "evals:readiness:json": "node scripts/check-prep-brief-evals-readiness.mjs --json",
    "evals:readiness:strict": "node scripts/check-prep-brief-evals-readiness.mjs --strict",
    "evals:readiness:strict:json": "node scripts/check-prep-brief-evals-readiness.mjs --strict --json",
    "evals:readiness:md": "node scripts/check-prep-brief-evals-readiness.mjs --markdown",
    "evals:readiness:summary": "node scripts/check-prep-brief-evals-readiness.mjs --summary",
    "evals:readiness:summary:strict": "node scripts/check-prep-brief-evals-readiness.mjs --summary --strict",
    "evals:readiness:snapshot": "node scripts/save-prep-brief-readiness-snapshot.mjs",
    "evals:readiness:snapshot:json": "node scripts/save-prep-brief-readiness-snapshot.mjs --format json",
    "evals:closeout": "node scripts/closeout-prep-brief-evals.mjs",
    "evals:closeout:dry-run": "node scripts/closeout-prep-brief-evals.mjs --dry-run",
    "evals:closeout:force": "node scripts/closeout-prep-brief-evals.mjs --force",
    "evals:closeout:json": "node scripts/closeout-prep-brief-evals.mjs --dry-run --json",
    "evals:help": "node scripts/evals-help.mjs",
    "evals:help:status": "node scripts/evals-help.mjs --status",
    "evals:help:json": "node scripts/evals-help.mjs --json",
    "evals:help:status:json": "node scripts/evals-help.mjs --status --json",
    "evals:doctor": "node scripts/evals-doctor.mjs",
    "evals:doctor:json": "node scripts/evals-doctor.mjs --json",
    "evals:doctor:strict": "node scripts/evals-doctor.mjs --strict",
    "evals:doctor:strict:json": "node scripts/evals-doctor.mjs --strict --json",
    "evals:ci:check": "node scripts/evals-ci-check.mjs",
    "evals:ci:check:json": "node scripts/evals-ci-check.mjs --json",
    "evals:seed:traces": "node scripts/seed-prep-brief-eval-traces.mjs",
    "evals:seed:traces:dry-run": "node scripts/seed-prep-brief-eval-traces.mjs --dry-run",
    "evals:sprint3:dod": "node scripts/check-prep-brief-sprint3-dod.mjs",
    "evals:sprint3:dod:json": "node scripts/check-prep-brief-sprint3-dod.mjs --json",
    "evals:sprint3:dod:strict": "node scripts/check-prep-brief-sprint3-dod.mjs --strict",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/nextjs": "^10.52.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "file-saver": "^2.0.5",
    "mammoth": "^1.12.0",
    "next": "^16.2.6",
    "pdf-parse": "^2.4.5",
    "posthog-js": "^1.372.8",
    "posthog-node": "^5.33.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "stripe": "^22.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
